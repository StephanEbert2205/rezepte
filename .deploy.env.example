# Deployment-Konfiguration für all-inkl.com (KAS)
# Kopiere diese Datei nach .deploy.env und trage die Werte ein.
# .deploy.env wird NICHT in Git eingecheckt.

DEPLOY_SSH_HOST=w021a129.kasserver.com
DEPLOY_SSH_USER=ssh-w021a129

# Pfad zum SSH-Key (Standard: ~/.ssh/id_ed25519)
# DEPLOY_SSH_KEY=C:\Users\se\.ssh\id_ed25519

# Alternativ Passwort (nur wenn kein SSH-Key vorhanden)
# DEPLOY_SSH_PASSWORD=dein_passwort

# Server-Pfade (normalerweise nicht ändern)
# DEPLOY_WEBROOT=/www/htdocs/w021a129/rezepte.familie-ebert.net
# DEPLOY_APP_DIR=/app/rezepte
